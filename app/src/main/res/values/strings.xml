    <string name="step_overlay_title">② 開啟懸浮窗權限</string>
    <string name="step_overlay_desc">用來顯示偵測狀態、點擊次數、快速控制按鈕。</string>
    <string name="open_overlay">前往懸浮窗設定</string>

    <string name="mode_title">運作模式</string>
    <string name="mode_semi">半自動搶紅包（只識別紅包）</string>
    <string name="mode_full">全自動（紅包 + 去看看）</string>
    <string name="mode_mahjong">全自動麻將（敬請期待）</string>
