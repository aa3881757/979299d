    <string name="accessibility_service_label">小勛紅包助手 自動點擊</string>
    <string name="accessibility_service_description">允許小勛紅包助手在偵測到指定圖片時自動執行點擊。本服務僅在開啟時運作，且不會收集個人資料。</string>

    <string name="title">小勛紅包助手</string>
    <string name="subtitle">三模式 + 麻將預留  v1.8</string>

    <string name="step_1_title">① 開啟無障礙服務</string>
    <string name="step_1_desc">在系統設定中找到「小勛紅包助手」並開啟。</string>
    <string name="open_accessibility">前往無障礙設定</string>
    <string name="status_on">✓ 已開啟</string>
